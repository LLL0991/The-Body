# ========== LLM 营养解析 API（三选一或自定义）==========
# 复制本文件为 .env，取消注释你要用的一组并填入 Key，重启 npm run dev

# ----- 1. OpenAI（国外）-----
# 获取 Key: https://platform.openai.com/api-keys
# VITE_LLM_API_KEY=sk-your-openai-key
# VITE_LLM_BASE_URL=https://api.openai.com/v1
# VITE_LLM_MODEL=gpt-4o-mini

# ----- 2. DeepSeek（国内，便宜好用）-----
# 获取 Key: https://platform.deepseek.com/
# VITE_LLM_API_KEY=sk-your-deepseek-key
# VITE_LLM_BASE_URL=https://api.deepseek.com/v1
# VITE_LLM_MODEL=deepseek-chat

# ----- 3. 智谱 GLM（国内）-----
# 获取 Key: https://open.bigmodel.cn/
# VITE_LLM_API_KEY=your-zhipu-key
# VITE_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# VITE_LLM_MODEL=glm-4-flash

# ----- 4. 阿里通义千问（国内）-----
# 获取 Key: https://dashscope.console.aliyun.com/
# VITE_LLM_API_KEY=your-dashscope-key
# VITE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VITE_LLM_MODEL=qwen-turbo

# ----- 5. 月之暗面 Moonshot / Kimi（国内）-----
# 获取 Key: https://platform.moonshot.cn/
# VITE_LLM_API_KEY=your-moonshot-key
# VITE_LLM_BASE_URL=https://api.moonshot.cn/v1
# VITE_LLM_MODEL=moonshot-v1-8k

# ----- 6. 百川 Baichuan（国内）-----
# 获取 Key: https://platform.baichuan-ai.com/
# VITE_LLM_API_KEY=your-baichuan-key
# VITE_LLM_BASE_URL=https://api.baichuan-ai.com/v1
# VITE_LLM_MODEL=Baichuan2-Turbo

# ----- 7. 硅基流动 SiliconFlow（国内，OpenAI 兼容）-----
# 获取 Key: https://cloud.siliconflow.cn/account/ak
# 国内: api.siliconflow.cn  国际: api.siliconflow.com
# VITE_LLM_API_KEY=sk-your-siliconflow-key
# VITE_LLM_BASE_URL=https://api.siliconflow.cn/v1
# VITE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# 若只填 Key 不填 BASE_URL/MODEL，默认为 OpenAI（需可访问）
# 兼容旧变量名：VITE_OPENAI_API_KEY 等同于 VITE_LLM_API_KEY
# 国内 API 跨域时开启代理（请求经本地转发，Key 不暴露）：
# VITE_LLM_USE_PROXY=true
